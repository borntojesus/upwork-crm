# Upwork OAuth2 app credentials
# Register at: https://www.upwork.com/developer/keys/apply
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=

# OAuth redirect URI — must match exactly what you registered in the Upwork app.
# Localhost-only (see memory: project_local).
UPWORK_REDIRECT_URI=http://127.0.0.1:8765/callback

# Agency tenant (Upwork Organization ID). REQUIRED for agency-scoped data.
# Without this header, the API silently returns the personal freelancer context.
# Find your org id via probe 01-me (user.organization.id).
UPWORK_ORG_ID=

# Optional: OAuth scopes (space-separated). Leave blank to request all granted scopes.
# Upwork uses scope keywords from app config; the portal shows what's available.
UPWORK_SCOPES=

# Local OAuth callback port (matches UPWORK_REDIRECT_URI).
OAUTH_CALLBACK_PORT=8765

# Client throttle: requests per second (leaky bucket). Default conservative.
UPWORK_RPS=1

# Google Sheets API key — enables Stage 1 live pull for the ranking dashboard.
# Pulls from "Alpina Worksheet → Ранжування профілю у Talent Search".
# Get one at https://console.cloud.google.com → APIs & Services → Credentials
# Enable "Google Sheets API" in the project first.
# Copy to viewer/.env.local (not this file) to keep it out of git.
GOOGLE_SHEETS_API_KEY=
